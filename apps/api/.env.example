NODE_ENV=development
PORT=4000
API_PREFIX=api
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/multi_catalogo
PLATFORM_ROOT_DOMAIN=midominio.local

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key

# Cloudflare R2 (media uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=multi-catalogo-media
R2_PUBLIC_URL=

# Resend (transactional emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@midominio.com

# PostHog (analytics)
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
